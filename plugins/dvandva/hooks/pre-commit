#!/usr/bin/env bash
# Dvandva delegating pre-commit wrapper (gate-first).
#
# Coexistence model: Dvandva owns core.hooksPath via its own gitignored hook
# dir.  This wrapper runs the Dvandva commit gate FIRST; on success it execs the
# prior pre-commit chain (Husky / lefthook / default) so foreign hooks keep
# firing.  On a gate block it propagates the gate's exit code WITHOUT delegating.
#
# Artifacts (lib + gate) are resolved relative to where THIS wrapper lives so the
# same bytes work both materialized in a target repo's .dvandva/githooks/ and as
# the dogfood .githooks/ in the Dvandva repo itself.
set -u

DVANDVA_HOOK_SELF="$0"
HOOK_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
DVANDVA_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
export DVANDVA_HOOK_SELF DVANDVA_REPO_ROOT

# Locate a co-located artifact by name.  Search order anchors on the wrapper's
# own location (materialized dir, then the source tree for the dogfood repo).
_dvandva_find() {
  local name="$1" base c
  for base in "$HOOK_DIR" "$HOOK_DIR/.." "$DVANDVA_REPO_ROOT"; do
    [[ -n "$base" ]] || continue
    for c in \
      "$base/$name" \
      "$base/scripts/$name" \
      "$base/plugins/dvandva/hooks/$name" \
      "$base/plugins/dvandva/scripts/$name"; do
      if [[ -f "$c" ]]; then printf '%s\n' "$c"; return 0; fi
    done
  done
  return 1
}

_lib="$(_dvandva_find dvandva-hook-lib.sh)" || {
  echo "Dvandva pre-commit: hook library not found; skipping gate (opt-in safety)." >&2
  exit 0
}
# shellcheck source=/dev/null
. "$_lib"

# Functional-probe short-circuit: prove the gate is wired without running it.
dvandva_hook_selfcheck "DVANDVA_GATE_WIRED" "$HOOK_DIR" && exit 0

# Run the Dvandva commit gate.  Block (propagate exit) without delegating.
if _gate="$(_dvandva_find dvandva-commit-gate.sh)"; then
  "$_gate" || exit $?
fi

# Gate passed (or absent) -> delegate to the prior pre-commit chain.
if _prior="$(resolve_prior_hook pre-commit)"; then
  exec "$_prior"
fi
exit 0
