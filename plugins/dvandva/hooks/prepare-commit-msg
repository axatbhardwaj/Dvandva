#!/usr/bin/env bash
# Dvandva delegating prepare-commit-msg wrapper (delegate-first, stamp-last).
#
# Order matters: the prior prepare-commit-msg chain (Husky / lefthook / default)
# runs FIRST with the original arguments and its exit code is propagated, THEN
# the Dvandva-Checkpoint: <N> trailer is appended at the very end so it survives
# any message rewriting the prior hook performed.  Stamping is skipped for merge
# and squash commits (auto-generated messages).
#
# Signature: prepare-commit-msg <msg-file> [<commit-source> [<sha1>]]
#   commit-source: message | template | merge | squash | commit
set -u

DVANDVA_HOOK_SELF="$0"
HOOK_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
DVANDVA_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
export DVANDVA_HOOK_SELF DVANDVA_REPO_ROOT

_dvandva_find() {
  local name="$1" base c
  for base in "$HOOK_DIR" "$HOOK_DIR/.." "$DVANDVA_REPO_ROOT"; do
    [[ -n "$base" ]] || continue
    for c in \
      "$base/$name" \
      "$base/scripts/$name" \
      "$base/plugins/dvandva/hooks/$name" \
      "$base/plugins/dvandva/scripts/$name"; do
      if [[ -f "$c" ]]; then printf '%s\n' "$c"; return 0; fi
    done
  done
  return 1
}

_lib="$(_dvandva_find dvandva-hook-lib.sh)" || {
  echo "Dvandva prepare-commit-msg: hook library not found; skipping (opt-in safety)." >&2
  exit 0
}
# shellcheck source=/dev/null
. "$_lib"

# Functional-probe short-circuit.
dvandva_hook_selfcheck "DVANDVA_PREPARE_WIRED" "$HOOK_DIR" && exit 0

# Delegate to the prior prepare-commit-msg FIRST; propagate its exit code.
if _prior="$(resolve_prior_hook prepare-commit-msg)"; then
  "$_prior" "$@" || exit $?
fi

# ---------------------------------------------------------------------------
# Stamp the Dvandva-Checkpoint trailer (skipped on merge/squash).
# Mirrors dvandva-commit-gate.sh role/baton logic so the hook works standalone.
# ---------------------------------------------------------------------------
COMMIT_MSG_FILE="${1:-}"
COMMIT_SOURCE="${2:-}"

case "$COMMIT_SOURCE" in
  merge|squash) exit 0 ;;
esac

REPO_ROOT="$DVANDVA_REPO_ROOT"
[[ -n "$REPO_ROOT" ]] || exit 0
[[ -n "$COMMIT_MSG_FILE" ]] || exit 0

# DVANDVA_ROLE must be set; if not, pre-commit already blocked (or no baton).
ROLE="${DVANDVA_ROLE:-}"
[[ -z "$ROLE" ]] && exit 0

# Collect baton candidates before requiring jq.  Repos without Dvandva state
# remain unaffected by this hook.
BATON_PATHS=()
if [[ -f "$REPO_ROOT/.dvandva/baton.json" ]]; then
  BATON_PATHS+=("$REPO_ROOT/.dvandva/baton.json")
fi
if [[ -d "$REPO_ROOT/.dvandva/runs" ]]; then
  while IFS= read -r -d '' bp; do
    BATON_PATHS+=("$bp")
  done < <(find "$REPO_ROOT/.dvandva/runs" -maxdepth 2 -name "baton.json" -print0 2>/dev/null)
fi

[[ ${#BATON_PATHS[@]} -eq 0 ]] && exit 0

if ! command -v jq >/dev/null 2>&1; then
  echo "Dvandva prepare-commit-msg error: jq is required to parse Dvandva baton files." >&2
  exit 1
fi

# Inline terminal-status test (mirrors dvandva-commit-gate.sh).
_is_terminal() {
  case "$1" in
    done|human_question|human_decision) return 0 ;;
    *) return 1 ;;
  esac
}

# Inline baton probe: count active batons and record allowed checkpoints.
CHECKPOINT=""
ACTIVE_COUNT=0
ALLOWED_CHECKPOINTS=()
ALLOWED_BATONS=()

_probe_baton() {
  local f="$1"
  [[ -f "$f" ]] || return
  if ! jq empty "$f" 2>/dev/null; then
    echo "Dvandva prepare-commit-msg error: malformed baton JSON: $f" >&2
    exit 1
  fi
  local status
  status="$(jq -r '.status // ""' "$f")"
  _is_terminal "$status" && return
  ACTIVE_COUNT=$((ACTIVE_COUNT + 1))
  local allowed
  allowed="$(jq --arg role "$ROLE" '
    ($role == .assignee) or
    ((.active_roles | type) == "array" and
     ((.active_roles | index($role)) != null))
  ' "$f")"
  [[ "$allowed" == "true" ]] || return
  ALLOWED_CHECKPOINTS+=("$(jq -r '.checkpoint // ""' "$f")")
  ALLOWED_BATONS+=("$f")
}

for bp in "${BATON_PATHS[@]}"; do
  _probe_baton "$bp"
done

if [[ "$ACTIVE_COUNT" -gt 1 ]]; then
  echo "Dvandva prepare-commit-msg error: $ACTIVE_COUNT active batons found — ambiguous active runs." >&2
  echo "Resolve to a single active run before committing." >&2
  exit 1
fi

# No active baton where ROLE is allowed -> nothing to stamp.
[[ "$ACTIVE_COUNT" -eq 0 ]] && exit 0
[[ ${#ALLOWED_CHECKPOINTS[@]} -eq 0 ]] && exit 0

CHECKPOINT="${ALLOWED_CHECKPOINTS[0]}"

# Skip if the trailer is already present.
grep -qE "^Dvandva-Checkpoint:[[:space:]]" "$COMMIT_MSG_FILE" 2>/dev/null && exit 0

# Append the trailer.  Two leading newlines ensure a blank-line separator from
# the body, which git's trailer convention requires.
printf '\n\nDvandva-Checkpoint: %s\n' "$CHECKPOINT" >> "$COMMIT_MSG_FILE"
exit 0
