{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dvandva.local/adversarial-loop/goal.schema.json",
  "title": "Adversarial loop goal",
  "description": "Runtime state for the bounded-nudge Stop gate. The gate treats a missing file as inert and a present malformed file as blocking.",
  "type": "object",
  "required": ["goal_id", "owner_session_id", "status", "acceptance", "steps"],
  "properties": {
    "goal_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
    },
    "owner_session_id": { "type": "string", "minLength": 1 },
    "mode": {
      "enum": ["cross-vendor", "cross-context"],
      "description": "Review separation mode. When absent, the gate treats it as cross-vendor for backward compatibility."
    },
    "status": { "enum": ["active", "done", "abandoned"] },
    "acceptance": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Step ids must be unique. JSON Schema cannot express uniqueness by an object property here; the gate enforces it.",
      "items": {
        "type": "object",
        "required": ["id", "kind", "author_family", "revision", "status", "artifact_path", "artifact_digest"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
          },
          "kind": { "enum": ["plan", "execute"] },
          "author_family": { "enum": ["claude", "gpt"] },
          "author_agent_id": {
            "type": "string",
            "description": "Required and non-empty by the gate when mode is cross-context."
          },
          "revision": { "type": "integer", "minimum": 1 },
          "status": { "enum": ["pending", "complete"] },
          "artifact_path": { "type": "string", "minLength": 1 },
          "artifact_digest": {
            "type": "string",
            "pattern": "^([0-9a-f]{64})?$",
            "description": "Empty while pending; the gate requires the sha256 of artifact_path when complete."
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
