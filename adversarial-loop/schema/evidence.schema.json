{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dvandva.local/adversarial-loop/evidence.schema.json",
  "title": "Adversarial loop evidence attempt",
  "description": "Append-only cross-family review evidence at .adversarial-loop/evidence/<goal_id>/<step_id>/<attempt_id>.json. A later attempt may pass after an earlier failure; attempts are never overwritten or deleted.",
  "type": "object",
  "required": ["goal_id", "step_id", "step_revision", "artifact_digest", "reviewer_family", "reviewer_model", "verdict", "findings", "transcript_ref", "created_at"],
  "properties": {
    "goal_id": { "type": "string", "minLength": 1 },
    "step_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
    },
    "step_revision": { "type": "integer", "minimum": 1 },
    "artifact_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "reviewer_family": { "enum": ["claude", "gpt"] },
    "reviewer_agent_id": {
      "type": "string",
      "description": "Required and non-empty by the gate when the goal mode is cross-context."
    },
    "reviewer_model": { "type": "string" },
    "verdict": { "enum": ["pass", "fail"] },
    "findings": { "type": "array" },
    "transcript_ref": { "type": "string" },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  },
  "additionalProperties": true
}
